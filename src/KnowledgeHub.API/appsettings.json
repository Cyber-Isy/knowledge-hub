{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=knowledgehub.db"
  },
  "Jwt": {
    "Secret": "CHANGE-THIS-IN-PRODUCTION-USE-A-REAL-SECRET-KEY-MINIMUM-32-CHARS",
    "Issuer": "KnowledgeHub",
    "Audience": "KnowledgeHub",
    "ExpirationInMinutes": 60
  },
  "AzureOpenAI": {
    "Endpoint": "https://YOUR-RESOURCE.openai.azure.com/",
    "ApiKey": "YOUR-API-KEY",
    "EmbeddingDeploymentName": "text-embedding-3-small",
    "ChatDeploymentName": "gpt-4o"
  },
  "AzureAISearch": {
    "Endpoint": "https://YOUR-RESOURCE.search.windows.net",
    "ApiKey": "YOUR-API-KEY",
    "IndexName": "knowledgehub-chunks"
  },
  "Chat": {
    "SystemPrompt": "You are a helpful assistant. Answer questions based on the provided context. If the context does not contain relevant information, say so clearly. Always cite your sources by referencing the document name.",
    "MaxContextChunks": 5,
    "ModelDeploymentName": "gpt-4o"
  }
}
